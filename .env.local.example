# 岗位避坑检测器 —— 环境变量约定
#
# 用法：把本文件复制为 .env.local，填入真实值。
#   cp .env.local.example .env.local
# .env.local 默认被 git 忽略，不会提交，请放心填 key。

# ========== 选择模型供应商 ==========
# 可选：deepseek（默认）| qwen
LLM_PROVIDER=deepseek

# ========== DeepSeek（默认供应商）==========
# 申请地址：https://platform.deepseek.com/  →  API keys
DEEPSEEK_API_KEY=
# 下面两项一般不用改，用默认值即可
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ========== 通义千问 Qwen（备用，LLM_PROVIDER=qwen 时启用）==========
# 申请地址：https://bailian.console.aliyun.com/  →  API-KEY
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ========== 截图识别（OCR / 视觉模型）==========
# 截图识别走通义千问视觉模型 qwen-vl-max（DeepSeek 不支持读图）。
# 申请地址同 Qwen：https://bailian.console.aliyun.com/ → API-KEY
# 若已填 QWEN_API_KEY，这里可留空，会自动复用。不填则前端"上传截图识别"会提示未配置。
QWEN_VL_API_KEY=
QWEN_VL_MODEL=qwen-vl-max
# QWEN_VL_BASE_URL 一般不用改，缺省复用 QWEN_BASE_URL
# OCR_TIMEOUT_MS 缺省 30000

# ========== 通用 ==========
# 单次 LLM 请求超时（毫秒）
LLM_TIMEOUT_MS=25000
