{
  "name": "job-risk-detector",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run check",
    "build": "next build",
    "check": "tsx scripts/test-scoring.ts && tsx scripts/test-analyze.ts && tsx scripts/eval.ts",
    "start": "next start",
    "lint": "next lint",
    "test:scoring": "tsx scripts/test-scoring.ts",
    "test:analyze": "tsx scripts/test-analyze.ts",
    "smoke": "tsx scripts/smoke-llm.ts",
    "eval": "tsx scripts/eval.ts",
    "eval:llm": "tsx scripts/eval.ts --llm",
    "check:links": "tsx scripts/check-links.ts",
    "check:freshness": "tsx scripts/check-freshness.ts"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
